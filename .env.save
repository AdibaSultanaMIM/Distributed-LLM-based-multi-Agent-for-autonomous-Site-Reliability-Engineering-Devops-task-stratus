### Agent ###
PROVIDER_AGENTS="openai"                  # Choose your LLM provider
MODEL_AGENTS="gpt-4o-2024-08-06"         # Set the model you want
API_KEY_AGENTS="sk-xxxxxxxxxxxxxxxx"     # Your OpenAI API key
REASONING_EFFORT_AGENTS="medium"         # optional
SEED_AGENTS=10
TOP_P_AGENTS=0.95
TEMPERATURE_AGENTS=0.0
THINKING_AGENTS="True"
THINKING_BUDGET_AGENTS=6000
MAX_TOKENS_AGENTS=16000

### Tools ###
PROVIDER_TOOLS="openai"
MODEL_TOOLS="gpt-4o-2024-08-06"
API_KEY_TOOLS="sk-xxxxxxxxxxxxxxxx"
REASONING_EFFORT_TOOLS="medium"
SEED_TOOLS=10
TOP_P_TOOLS=0.95
TEMPERATURE_TOOLS=0.0
THINKING_TOOLS="True"
THINKING_BUDGET_TOOLS=6000
MAX_TOKENS_TOOLS=16000

### Service related ###
GOD_MODE="False"
GRAFANA_SERVICE_ACCOUNT_TOKEN="auth_disabled"
KUBECONFIG="$HOME/.kube/config"          # default WSL path for kube config
GRAFANA_URL="http://localhost:8080/grafana"
TOPOLOGY_URL="http://localhost:8081"

### Evaluation related ###
BENCHMARK="AIOpsLab"                     # Either ITBench or AIOpsLab
WX_PROJECT_ID=""                          # only needed for watsonx
AGENT_TASK_DIRECTORY="config"
SRE_AGENT_EVALUATION_DIRECTORY="stratus_eval"
SRE_AGENT_NAME_VERSION_NUMBER=1
EXP_NAME=1
INCIDENT_NUMBER=1
OTEL_SDK_DISABLED="False"

# NEW: Path to AIOpsLab repo (so test_agent.sh finds kind-config-x86.yaml)
AIOPSLAB_ROOT="$HOME/Documents/DistributedComputingSystemProject/AIOpsLab"
