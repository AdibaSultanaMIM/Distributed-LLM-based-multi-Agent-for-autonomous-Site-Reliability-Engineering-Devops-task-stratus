# Nginx Rate Limiting Configuration
# This file contains environment variables for configuring rate limiting

# ============================================================================
# Nginx Proxy Configuration
# ============================================================================

# Enable or disable the nginx proxy for LLM API calls
# Set to "true" to route all LLM API calls through the nginx proxy
# Set to "false" to make direct API calls (bypasses rate limiting)
USE_NGINX_PROXY=true

# Nginx proxy hostname (used in docker-compose)
NGINX_PROXY_HOST=nginx-llm-proxy

# ============================================================================
# Proxy URLs for Different LLM Providers
# ============================================================================

# OpenAI API proxy endpoint
OPENAI_PROXY_URL=http://nginx-llm-proxy:8080

# Azure OpenAI API proxy endpoint
AZURE_OPENAI_PROXY_URL=http://nginx-llm-proxy:8081

# Anthropic API proxy endpoint
ANTHROPIC_PROXY_URL=http://nginx-llm-proxy:8082

# ============================================================================
# Rate Limiting Settings (Applied by Nginx)
# ============================================================================

# Request Rate Limit: Number of requests per minute
# Default: 10 requests per minute (10r/m)
# Modify nginx.conf to change this value (limit_req_zone rate parameter)
RATE_LIMIT_REQUESTS_PER_MINUTE=10

# Burst Capacity: Number of requests that can burst above the rate limit
# These requests will be queued and processed with delay
# Default: 5 requests
RATE_LIMIT_BURST=5

# Delay Threshold: Number of burst requests to process immediately
# Requests beyond this threshold will be delayed
# Default: 3 requests
RATE_LIMIT_DELAY_THRESHOLD=3

# Connection Limit: Maximum concurrent connections per IP
# Default: 10 connections
RATE_LIMIT_MAX_CONNECTIONS=10

# ============================================================================
# Token Limiting (Application Level)
# ============================================================================

# Maximum tokens per request (enforced by application)
MAX_TOKENS_AGENTS=2000
MAX_TOKENS_TOOLS=2000

# To implement per-minute token limiting, you would need to:
# 1. Track token usage in a time-windowed counter
# 2. Implement token bucket algorithm in the application
# 3. Or use a Redis-based rate limiter with token counting

# ============================================================================
# Retry Configuration (When Rate Limit is Hit)
# ============================================================================

# Maximum number of retry attempts when rate limit is exceeded
RATE_LIMIT_MAX_RETRIES=5

# Initial delay in seconds before first retry
RATE_LIMIT_RETRY_DELAY=60

# Exponential backoff factor for subsequent retries
# Delay = RETRY_DELAY * (BACKOFF_FACTOR ^ attempt_number)
# Example: 60s, 90s, 135s, 202.5s, 303.75s
RATE_LIMIT_BACKOFF_FACTOR=1.5

# ============================================================================
# Nginx Timeout Settings
# ============================================================================

# Proxy connection timeout (seconds)
NGINX_PROXY_CONNECT_TIMEOUT=60

# Proxy send timeout (seconds)
NGINX_PROXY_SEND_TIMEOUT=300

# Proxy read timeout (seconds)
NGINX_PROXY_READ_TIMEOUT=300

# ============================================================================
# Monitoring and Logging
# ============================================================================

# Enable detailed rate limiting logs
NGINX_RATE_LIMIT_LOG_LEVEL=warn

# Health check endpoint
NGINX_HEALTH_CHECK_PORT=8888

# ============================================================================
# Advanced Token Limiting Strategy (Future Implementation)
# ============================================================================

# Uncomment and configure these for advanced token-based rate limiting
# This would require additional implementation in the application layer

# TOKEN_LIMIT_PER_MINUTE=100000
# TOKEN_LIMIT_WINDOW_SECONDS=60
# TOKEN_LIMIT_STORAGE=redis  # Options: memory, redis
# REDIS_URL=redis://localhost:6379/0

# ============================================================================
# Notes
# ============================================================================

# Rate Limiting Hierarchy:
# 1. Nginx handles request-level rate limiting (requests per minute)
# 2. Application handles retry logic with exponential backoff
# 3. LLM provider may have additional rate limits

# To modify rate limits in nginx.conf:
# - Edit nginx/nginx.conf
# - Change the 'rate' parameter in limit_req_zone directive
# - Example: limit_req_zone $binary_remote_addr zone=llm_req_limit:10m rate=10r/m;
#   Change '10r/m' to your desired rate (e.g., '20r/m' for 20 requests per minute)

# To implement token-based rate limiting:
# - You'll need to add token counting logic in the application
# - Track tokens used per request (from LLM response)
# - Implement a sliding window or token bucket algorithm
# - Store counts in Redis or in-memory cache

# Example Token Bucket Implementation Pseudocode:
# - bucket_capacity = TOKEN_LIMIT_PER_MINUTE
# - refill_rate = TOKEN_LIMIT_PER_MINUTE / 60  (tokens per second)
# - Before each request: check if bucket has enough tokens
# - After each request: deduct actual tokens used from bucket
# - Bucket refills continuously at refill_rate
