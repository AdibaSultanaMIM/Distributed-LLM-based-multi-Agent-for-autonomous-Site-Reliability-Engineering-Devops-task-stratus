### Service related ###
GOD_MODE="False" # Setting this to "True" will disable safeguards during mitigation step
GRAFANA_SERVICE_ACCOUNT_TOKEN="auth_disabled" 
KUBECONFIG="$HOME/.kube/config" # path to the kube config file; it can be "/app/stratus/config" in the image
GRAFANA_URL="http://localhost:8080/grafana"
TOPOLOGY_URL="http://localhost:8081"

### Evaluation related ###
BENCHMARK="AIOpsLab" # Either ITBench or AIOpsLab
WX_PROJECT_ID="" # need this if using watsonx
AGENT_TASK_DIRECTORY="config"
SRE_AGENT_EVALUATION_DIRECTORY="stratus_eval"
SRE_AGENT_NAME_VERSION_NUMBER=1
EXP_NAME=1 
INCIDENT_NUMBER=1
OTEL_SDK_DISABLED="False"

### Knowledge Graph related ###
NEO4J_URI="" # e.g. "neo4j+s://your-instance.databases.neo4j.io"
NEO4J_USERNAME="" # e.g. "neo4j"
NEO4J_PASSWORD=""
NEO4J_ENABLED="False" # Set to "True" to enable knowledge graph integration

### Detection Agent and Baseline Storage ###
DETECTION_AGENT_MODE="hybrid" # Options: "heuristic", "statistical", "hybrid"
BASELINE_WINDOW_HOURS="48" # Rolling window duration for normal baseline
BASELINE_REFRESH_MINUTES="15" # How often to refresh baseline stats
ELASTICSEARCH_HOSTS="" # e.g. "http://localhost:9200" or your Elasticsearch cluster
ELASTICSEARCH_USERNAME="" # Optional, if using authentication
ELASTICSEARCH_PASSWORD="" # Optional, if using authentication
ELASTICSEARCH_INDEX_PREFIX="stratus-baseline" # Prefix for baseline data indices